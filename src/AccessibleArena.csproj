<Project Sdk="Microsoft.NET.Sdk">

  <!-- Exclude archived code from compilation -->
  <ItemGroup>
    <Compile Remove="**/old/**/*.cs" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net472</TargetFramework>
    <AssemblyName>AccessibleArena</AssemblyName>
    <RootNamespace>AccessibleArena</RootNamespace>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <!-- Generate VersionInfo.g.cs so MelonInfo can use a const from Directory.Build.props -->
  <Target Name="GenerateVersionInfo" BeforeTargets="CoreCompile">
    <ItemGroup>
      <_VersionLines Include="// Auto-generated from Directory.Build.props — do not edit" />
      <_VersionLines Include="internal static class VersionInfo { internal const string Value = &quot;$(ModVersion)&quot;%3B }" />
    </ItemGroup>
    <WriteLinesToFile File="$(IntermediateOutputPath)VersionInfo.g.cs" Lines="@(_VersionLines)" Overwrite="true" />
    <ItemGroup>
      <Compile Include="$(IntermediateOutputPath)VersionInfo.g.cs" />
    </ItemGroup>
  </Target>

  <!-- Game install path - adjust if your MTGA is installed elsewhere -->
  <PropertyGroup>
    <MtgaPath>C:\Program Files\Wizards of the Coast\MTGA</MtgaPath>
    <MtgaManagedPath>$(MtgaPath)\MTGA_Data\Managed</MtgaManagedPath>
    <MelonLoaderPath>$(MtgaPath)\MelonLoader\net35</MelonLoaderPath>
  </PropertyGroup>

  <ItemGroup>
    <!-- MelonLoader / Harmony -->
    <Reference Include="0Harmony">
      <HintPath>$(MelonLoaderPath)\0Harmony.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="MelonLoader">
      <HintPath>$(MelonLoaderPath)\MelonLoader.dll</HintPath>
      <Private>false</Private>
    </Reference>

    <!-- Unity -->
    <Reference Include="UnityEngine">
      <HintPath>$(MtgaManagedPath)\UnityEngine.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(MtgaManagedPath)\UnityEngine.CoreModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.UI">
      <HintPath>$(MtgaManagedPath)\UnityEngine.UI.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.InputLegacyModule">
      <HintPath>$(MtgaManagedPath)\UnityEngine.InputLegacyModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.UIModule">
      <HintPath>$(MtgaManagedPath)\UnityEngine.UIModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Unity.TextMeshPro">
      <HintPath>$(MtgaManagedPath)\Unity.TextMeshPro.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Unity.InputSystem">
      <HintPath>$(MtgaManagedPath)\Unity.InputSystem.dll</HintPath>
      <Private>false</Private>
    </Reference>

    <!-- MTGA game assemblies -->
    <Reference Include="Assembly-CSharp">
      <HintPath>$(MtgaManagedPath)\Assembly-CSharp.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Core">
      <HintPath>$(MtgaManagedPath)\Core.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Wizards.Arena.Models">
      <HintPath>$(MtgaManagedPath)\Wizards.Arena.Models.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Wizards.Arena.Enums">
      <HintPath>$(MtgaManagedPath)\Wizards.Arena.Enums.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Wizards.Mtga.Metadata">
      <HintPath>$(MtgaManagedPath)\Wizards.Mtga.Metadata.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Wizards.Mtga.Interfaces">
      <HintPath>$(MtgaManagedPath)\Wizards.Mtga.Interfaces.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="ZFBrowser">
      <HintPath>$(MtgaManagedPath)\ZFBrowser.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="..\lang\*.json" LogicalName="lang.%(Filename)%(Extension)" />
  </ItemGroup>

</Project>
